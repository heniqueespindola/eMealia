{
  "expo": {
    "name": "eMealia",
    "slug": "emealia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "https://via.placeholder.com/1024",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1B2632"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mocruz.emealia",
      "infoPlist": {
        "NSCameraUsageDescription": "Usado para escanear códigos de barras de produtos alimentares.",
        "NSPhotoLibraryUsageDescription": "Usado para escolher foto de perfil."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B2632"
      },
      "package": "com.mocruz.emealia",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Usado para escanear códigos de barras de produtos alimentares." }
      ]
    ],
    "scheme": "emealia",
    "experiments": {
      "typedRoutes": false
    }
  }
}
